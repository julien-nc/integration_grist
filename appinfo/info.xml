<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>integration_grist</id>
	<name>Grist Integration</name>
	<summary>Connect to your Grist instance to search for documents and add links via Smart Picker</summary>
	<description><![CDATA[The Grist integration connects Nextcloud to a self-hosted or vendor-hosted Grist account, providing a 
	unified search provider and a smart picker component for documents.]]></description>
	<version>1.0.2</version>
	<licence>AGPL-3.0-or-later</licence>
	<author mail="jana.peper@nextcloud.com">Jana Peper</author>
	<namespace>IntegrationGrist</namespace>
	<category>office</category>
	<category>organization</category>
	<bugs>https://github.com/nextcloud/integration_grist</bugs>
	<screenshot>https://github.com/nextcloud/integration_grist/raw/main/img/screenshot1.png</screenshot>
	<screenshot>https://github.com/nextcloud/integration_grist/raw/main/img/screenshot2.png</screenshot>
	<dependencies>
		<nextcloud min-version="35" max-version="35"/>
	</dependencies>
	<settings>
		<personal>OCA\IntegrationGrist\Settings\Personal</personal>
		<personal-section>OCA\IntegrationGrist\Settings\PersonalSection</personal-section>
	</settings>
</info>
